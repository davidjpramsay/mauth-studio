{
  "name": "mauth",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "scripts": {
    "dev:web": "pnpm --dir apps/web dev --host 0.0.0.0",
    "build:web": "pnpm --dir apps/web build",
    "dev:api": "cd apps/api && uv run uvicorn app.main:app --reload --reload-dir app --reload-dir ../../packages --reload-dir ../../configs --host 0.0.0.0 --port 8000",
    "dev:launch": "node scripts/mauth-launch.mjs",
    "dev:launch:desktop": "node scripts/mauth-launch.mjs --replace-ambiguous",
    "dev:launch:replace": "node scripts/mauth-launch.mjs --replace",
    "dev:status": "node scripts/mauth-launch.mjs --status",
    "dev:stop": "node scripts/mauth-launch.mjs --stop",
    "macos:install-launcher": "node scripts/install-macos-launcher.mjs",
    "agent:mcp": "node scripts/mauth-agent-mcp.mjs",
    "agent:doctor": "node scripts/mauth-agent-doctor.mjs",
    "smoke:diagram-gallery": "node scripts/diagram-gallery-smoke.mjs",
    "smoke:editor:columns": "node scripts/editor-columns-smoke.mjs",
    "smoke:editor:inspector": "node scripts/editor-columns-smoke.mjs",
    "smoke:context-menu-actions": "node scripts/context-menu-actions-smoke.mjs",
    "smoke:graph3d": "node scripts/graph3d-render-smoke.mjs",
    "smoke:file-manager": "node scripts/file-manager-smoke.mjs",
    "smoke:external-folder-autosave": "node scripts/external-folder-autosave-smoke.mjs",
    "smoke:agent-bridge": "node scripts/agent-bridge-smoke.mjs",
    "audit:canvas-assets": "node scripts/canvas-question-assets-audit.mjs",
    "test:api": "cd apps/api && uv run pytest",
    "test:web-actions": "node --experimental-strip-types --test apps/web/src/lib/*Actions.test.ts apps/web/src/lib/documentFileNaming.test.ts apps/web/src/lib/mathDelimiters.test.ts apps/web/src/lib/functionCurveSampling.test.ts apps/web/src/lib/graphFunctionDomains.test.ts apps/web/src/lib/logoLibrary.test.ts apps/web/src/lib/mauthActionProposal.test.ts apps/web/src/lib/mauthActionValidation.test.ts apps/web/src/lib/mauthAgentSnapshot.test.ts apps/web/src/lib/mauthDiagramInspection.test.ts apps/web/src/lib/nativeBrowserDialogs.test.ts apps/web/src/lib/projectFileVersionPreview.test.ts apps/web/src/lib/projectSaveConflicts.test.ts apps/web/src/lib/solutionBlockVisibility.test.ts apps/web/src/lib/solutionValidation.test.ts apps/web/src/hooks/useEditorCloseController.test.ts apps/web/src/hooks/useUnsavedChangesBeforeUnloadController.test.ts apps/web/src/components/editor/selectionInspectorPatches.test.ts apps/web/src/components/graphs/functionGraphGeometry.test.ts apps/web/src/components/graphs/graphTypography.test.ts",
    "test:plotly": "node --experimental-strip-types --test packages/diagram-plotly/tests/*.test.ts",
    "test": "pnpm test:api && pnpm test:web-actions && pnpm test:plotly && pnpm build:web",
    "format": "pnpm format:web && pnpm format:api",
    "format:web": "pnpm exec prettier --write .",
    "format:api": "cd apps/api && uv run ruff format app tests ../../packages/question-engine ../../packages/formatting-engine ../../packages/marking-engine",
    "format:check": "pnpm format:check:web && pnpm format:check:api",
    "format:check:web": "pnpm exec prettier --check .",
    "format:check:api": "cd apps/api && uv run ruff format --check app tests ../../packages/question-engine ../../packages/formatting-engine ../../packages/marking-engine",
    "lint": "pnpm lint:web && pnpm lint:api",
    "lint:web": "pnpm exec eslint apps/web packages/shared packages/diagram-plotly packages/diagram-penrose",
    "lint:api": "cd apps/api && uv run ruff check app tests ../../packages/question-engine ../../packages/formatting-engine ../../packages/marking-engine",
    "check": "pnpm format:check && pnpm lint && pnpm test"
  },
  "workspaces": [
    "apps/web",
    "packages/shared",
    "packages/diagram-penrose",
    "packages/diagram-plotly"
  ],
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@playwright/test": "^1.59.1",
    "eslint": "^10.2.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.5.0",
    "prettier": "^3.8.3",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "typescript-eslint": "^8.59.1",
    "zod": "^4.4.3"
  }
}
